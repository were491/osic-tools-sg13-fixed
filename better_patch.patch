         "no_parallel_res": "true" if args.no_parallel_res else "false",
         "combine_devices": "true" if args.combine_devices else "false",
+        "enable_tap_extraction": "true" if args.enable_tap_extraction else "false",
         "purge": "true" if args.purge else "false",
         "purge_nets": "true" if args.purge_nets else "false",
         "topcell": get_run_top_cell_name(args, layout_path),
@@ -777,6 +778,7 @@ def main(lvs_run_dir: str, args: argparse.Namespace):
                [--topcell=<topcell_name>] [--run_mode=<run_mode>]
                [--no_net_names] [--spice_comments] [--net_only] [--no_simplify]
                [--no_series_res] [--no_parallel_res] [--combine_devices] [--top_lvl_pins]
+               [--enable_tap_extraction]
                [--purge] [--purge_nets] [--ignore_top_ports_mismatch]
                [--implicit_nets=<nets>]
     """
@@ -827,6 +829,11 @@ def main(lvs_run_dir: str, args: argparse.Namespace):
     parser.add_argument("--no_series_res", action="store_true", help="Disable resistor series simplification.")
     parser.add_argument("--no_parallel_res", action="store_true", help="Disable resistor parallel simplification.")
     parser.add_argument("--combine_devices", action="store_true", help="Enable generic device combination.")
+    parser.add_argument(
+        "--enable_tap_extraction",
+        action="store_true",
+        help="Extract ntap1/ptap1 as devices. Disabled by default to align with Magic+Netgen LVS.",
+    )
     parser.add_argument("--top_lvl_pins", action="store_true", help="Create top-level pins in netlists.")
     parser.add_argument("--purge", action="store_true", help="Purge unused nets/devices.")
     parser.add_argument("--purge_nets", action="store_true", help="Purge floating nets.")
diff --git a/ihp-sg13g2/libs.tech/klayout/tech/lvs/sg13g2.lvs b/ihp-sg13g2/libs.tech/klayout/tech/lvs/sg13g2.lvs
index e99d0fed4..dfe8be1cd 100755
--- a/ihp-sg13g2/libs.tech/klayout/tech/lvs/sg13g2.lvs
+++ b/ihp-sg13g2/libs.tech/klayout/tech/lvs/sg13g2.lvs
@@ -178,6 +178,13 @@ PARALLEL_RES = !bool_check?($no_parallel_res)
 
 logger.info("Selected PARALLEL_RES option: #{PARALLEL_RES}")
 
+# ENABLE_TAP_EXTRACTION
+# true: extract ntap1/ptap1 as devices (schematic must contain matching taps).
+# false (default): skip ntap/ptap device extraction to align with Magic+Netgen LVS.
+ENABLE_TAP_EXTRACTION = bool_check?($enable_tap_extraction)
+
+logger.info("Selected ENABLE_TAP_EXTRACTION option: #{ENABLE_TAP_EXTRACTION}")
+
 # === RUN MODE ===
 case $run_mode
 when 'deep'
