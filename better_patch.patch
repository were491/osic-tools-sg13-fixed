From f0c64bdd4d5024e0696450c9043772578729d6ca Mon Sep 17 00:00:00 2001
From: Simon Dorrer <simon.dorrer@jku.at>
Date: Wed, 1 Jul 2026 23:13:04 +0200
Subject: [PATCH 1/4] added `enable_tap_extraction` option to KLayout LVS

---
 .../libs.tech/klayout/tech/lvs/README.md      |  3 ++
 .../tech/lvs/rule_decks/tap_extraction.lvs    | 47 +++++++++++--------
 .../libs.tech/klayout/tech/lvs/run_lvs.py     |  7 +++
 .../libs.tech/klayout/tech/lvs/sg13g2.lvs     |  7 +++
 .../unit/diode_devices/layout/isolbox.yaml    |  4 ++
 .../unit/tap_devices/layout/ntap1.yaml        |  4 ++
 .../unit/tap_devices/layout/ptap1.yaml        |  4 ++
 .../klayout/tech/macros/sg13g2_lvs.lym        |  2 +
 .../tech/macros/sg13g2_lvs_options.lym        |  9 ++++
 9 files changed, 30 insertions(+), 8 deletions(-)

diff --git a/ihp-sg13g2/libs.tech/klayout/tech/lvs/README.md b/ihp-sg13g2/libs.tech/klayout/tech/lvs/README.md
index d635a42a9..57e22e2d3 100644
--- a/ihp-sg13g2/libs.tech/klayout/tech/lvs/README.md
+++ b/ihp-sg13g2/libs.tech/klayout/tech/lvs/README.md
@@ -60,6 +60,7 @@ run_lvs.py [--layout=<layout_path>]
            [--topcell=<topcell_name>] [--run_mode=<run_mode>]
            [--no_net_names] [--spice_comments] [--net_only] [--no_simplify]
            [--no_series_res] [--no_parallel_res] [--combine_devices] [--top_lvl_pins]
+           [--enable_tap_extraction]
            [--purge] [--purge_nets] [--ignore_top_ports_mismatch]
            [--implicit_nets=<nets>]
 ```
@@ -94,6 +95,8 @@ run_lvs.py [--layout=<layout_path>]
 
 - `--combine_devices`                 Enables device combination for both layout and schematic netlists.
 
+- `--enable_tap_extraction`           Extracts `ntap1`/`ptap1` as devices. Disabled by default so taps are not required in the schematic, matching Magic+Netgen LVS behavior.
+
 - `--top_lvl_pins`                    Creates pins for top-level circuits in both layout and schematic netlists.
 
 - `--purge`                           Removes unused nets from both layout and schematic netlists.
diff --git a/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_extraction.lvs b/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_extraction.lvs
index 7376a2818..a41bf8280 100644
--- a/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_extraction.lvs
+++ b/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_extraction.lvs
@@ -23,24 +23,31 @@
 
 logger.info('Starting Taps EXTRACTION')
 
-# ntap1
-logger.info('Extracting ntap1 device')
-# ntap1 is extracted with the diode extractor because the geometry is a nested
-# junction (tie inside well). We map diode regions as:
-#   - P => ntap1_tie  (tie contact)
-#   - N => ntap1_well (nwell body)
-# This preserves PDK terminal order in the written netlist as "TIE WELL".
-# See: https://www.klayout.de/doc/manual/lvs_device_extractors.html#h2-117
-cheat("*") {
-  extract_devices(diode('ntap1', CustomTap), { 'P' => ntap1_tie, 'N' => ntap1_well })
-}
-
-# ptap1
-logger.info('Extracting ptap1 device')
-# ptap1 follows the same P/N region mapping rule:
-#   - P => ptap1_tie (tie contact)
-#   - N => ptap1_sub (substrate/body region)
-cheat("*") {
-  extract_devices(diode('ptap1', CustomTap), { 'P' => ptap1_tie, 'N' => ptap1_sub })
-}
+# ntap1/ptap1 device extraction is gated by ENABLE_TAP_EXTRACTION (see sg13g2.lvs).
+# When disabled (default), taps are not extracted as devices so the schematic does
+# not need to contain them, matching Magic+Netgen LVS behavior. The tap tie regions
+# are still connected to their well/substrate nets via tap_connections.lvs.
+if ENABLE_TAP_EXTRACTION
+  # ntap1
+  logger.info('Extracting ntap1 device')
+  # ntap1 is extracted with the diode extractor because the geometry is a nested
+  # junction (tie inside well). We map diode regions as:
+  #   - P => ntap1_tie  (tie contact)
+  #   - N => ntap1_well (nwell body)
+  # This preserves PDK terminal order in the written netlist as "TIE WELL".
+  # See: https://www.klayout.de/doc/manual/lvs_device_extractors.html#h2-117
+  cheat("*") {
+    extract_devices(diode('ntap1', CustomTap), { 'P' => ntap1_tie, 'N' => ntap1_well })
+  }
 
+  # ptap1
+  logger.info('Extracting ptap1 device')
+  # ptap1 follows the same P/N region mapping rule:
+  #   - P => ptap1_tie (tie contact)
+  #   - N => ptap1_sub (substrate/body region)
+  cheat("*") {
+    extract_devices(diode('ptap1', CustomTap), { 'P' => ptap1_tie, 'N' => ptap1_sub })
+  }
+else
+  logger.info('ENABLE_TAP_EXTRACTION is disabled: skipping ntap1/ptap1 device extraction.')
+end
diff --git a/ihp-sg13g2/libs.tech/klayout/tech/lvs/run_lvs.py b/ihp-sg13g2/libs.tech/klayout/tech/lvs/run_lvs.py
