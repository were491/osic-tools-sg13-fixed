+++ b/ihp-sg13g2/libs.tech/klayout/tech/macros/sg13g2_lvs.lym
@@ -58,6 +58,7 @@ DEFAULT_OPTIONS = {
   'no_series_res' => false,
   'no_parallel_res' => false,
   'combine_devices' => false,
+  'enable_tap_extraction' => false,
