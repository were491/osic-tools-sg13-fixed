From 40e9358b288626425893cb00e4cf3c8170e84da2 Mon Sep 17 00:00:00 2001
From: Simon Dorrer <simon.dorrer@jku.at>
Date: Fri, 3 Jul 2026 09:28:09 +0200
Subject: [PATCH 3/4] updated `tap_connections.lvs` to connect tie / well and
 tie / sub

---
 .../klayout/tech/lvs/rule_decks/tap_connections.lvs    | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_connections.lvs b/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_connections.lvs
index f922e2a68..83a078dd3 100644
--- a/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_connections.lvs
+++ b/ihp-sg13g2/libs.tech/klayout/tech/lvs/rule_decks/tap_connections.lvs
@@ -30,3 +30,13 @@ connect(ntap1_well, nwell_drw)
 # ptap1
 connect(ptap1_tie, cont_drw)
 connect(ptap1_sub, pwell)
+
+# When tap extraction is disabled (see DISABLE_TAP_EXTRACTION in sg13g2.lvs), the
+# ntap1/ptap1 devices are not created. The n+/p+ tie is physically the same node as
+# its well/substrate, so merge them here. This keeps the well/substrate bulk connected
+# to the power nets through the tie contact, matching Magic+Netgen LVS (which does not
+# model taps as devices). See IHP-Open-PDK issue #955.
+if DISABLE_TAP_EXTRACTION
+  connect(ntap1_tie, ntap1_well)
+  connect(ptap1_tie, ptap1_sub)
+end

