     'no_series_res' => false,
     'no_parallel_res' => false,
     'combine_devices' => false,
+    'enable_tap_extraction' => false,
     'top_lvl_pins' => false,
     'ignore_top_ports_mismatch' => false,
     'purge' => false,
@@ -270,6 +271,12 @@ module SG13G2LVSOptions
       options['combine_devices'],
