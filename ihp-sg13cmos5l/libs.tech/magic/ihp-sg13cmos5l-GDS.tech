 m1  MET1RES
 m1  MET1FILL
 m1  MET1SLIT
 v1  VIA1
 m2  MET2
 m2  MET2TXT
 m2  MET2PIN
 m2  MET2RES
 m2  MET2FILL
 m2  MET2SLIT
 v2  VIA2
 m3  MET3
 m3  MET3TXT
 m3  MET3PIN
 m3  MET3RES
 m3  MET3FILL
 m3  MET3SLIT
 v3  VIA3
 m4  MET4
 m4  MET4TXT
 m4  MET4PIN
 m4  MET4RES
 m4  MET4FILL
 m4  MET4SLIT
 v4  VIA4
 m5  MET5
 m5  MET5TXT
 m5  MET5PIN
 m5  MET5RES
 m5  MET5FILL
 m5  MET5SLIT

 g   GLASS
 g   PADPIN

 id1 BOUND
 id1 SEALBOUND
 id1 INDBOUND
 id2 DIODE
 id2 RESDEF
 id3 INDUCTOR
 id3 INDPIN
 id3 INDTXT
 id4 CAPID
 id5 FILLBLOCK
 id6 ESDID
 id6 SRAMID
 id6 DIGITALID
 id6 BIPOLARID
 id6 EDGESEAL
 id7 HEATRES
 id7 HEATTRANS
 id8 IPROBE
 id8 DPROBE
 id8 THRUVIA
 id8 PADID
 id9 RFMEMS
 id9 TSVID

 bd  DIFFBLOCK
 bd  DIFFNORCX
 bp  POLYBLOCK
 bp  POLYNORCX
 b1  MET1BLOCK
 b1  MET1NORCX
 b2  MET2BLOCK
 b2  MET2NORCX
 b3  MET3BLOCK
 b3  MET3NORCX
 b4  MET4BLOCK
 b4  MET4NORCX
 b5  MET5BLOCK
 b5  MET5NORCX

 c   LVSTEXT
 c   COMMENT
 c   NORCX

