tech
    format 32
    ihp-sg13cmos5l-GDS
end

version
    version 1.0.0
    description "IHP SG13CMOS5L: Vendor GDS layers and supplementary DRC"
    requires magic-8.3.124
end

#------------------------------------------------------------------------------
# This tech file represents all GDS layers exactly in magic with no boolean
# transforms to generated layer types.  It can be used to manipulate GDS and
# is better for some DRC checks and for fill pattern generation.  However, it
# does not properly understand connectivity and cannot be used for extraction.
#------------------------------------------------------------------------------

planes
 well,w
 implant1,i1
 implant2,i2
 implant3,i3
 implant4,i4
 implant5,i5
 active,a
 poly,p
 contact,co
 metal1,m1
 via1,v1
 metal2,m2
 via2,v2
 metal3,m3
 via3,v3
 metal4,m4
 via4,v4
 metal5,m5
 glass,g
 blockd,bd
 blockp,bp
 block1,b1
 block2,b2
 block3,b3
 block4,b4
 block5,b5
 ident1,id1
 ident2,id2
 ident3,id3
 ident4,id4
 ident5,id5
 ident6,id6
 ident7,id7
 ident8,id8
 ident9,id9
 comment,c
 error,e
end

types
 w   NWELL
 w   NWELLPIN
 w   SUBS
 w   DIGSUB
 w   SUBTXT
 w   PWELLBLK
 a   DIFF
 a   DIFFMASK
 a   DIFFFILL
 a   DIFFPIN

 i1  PSD
 i2  NSD
