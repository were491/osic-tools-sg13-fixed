<Component
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="Component.xsd"
    library="IHP SG13G2 Standard Cells"
    names="sg13g2_or4_1" schematic_id="or">
    <Description>
        4-input OR gate
    </Description>
    <Models>
        <DefaultModel value="sg13g2_or4_1"></DefaultModel>
        <SpiceModel value="sg13g2_or4_1"></SpiceModel>
    </Models>
    <Netlists>
        <NgspiceNetlist value="{{{Letter}}}::schematic_id='nequal'or{PartCounter} {nets} {VDD} {VSS} {{{model}}}::model='nonempty'"></NgspiceNetlist>
        <CDLNetlist value="{NgspiceNetlist}"></CDLNetlist>
    </Netlists>
    <Symbols>
        <Symbol id="Standard">
            <File>{QUCS_S_COMPONENTS_LIBRARY}/sym/OR4.sym</File>
        </Symbol>
    </Symbols>
    <Parameters>
        <Parameter name="Letter" unit="" default_value="X" show="false">
            <Description>Spice prefix</Description>
        </Parameter>
        <Parameter name="model" unit="" default_value="sg13g2_or4_1" show="false">
            <Description>[sg13g2_or4_1]</Description>
        </Parameter>
        <Parameter name="VDD" unit="" default_value="VDD" show="false">
            <Description>VDD terminal net name</Description>
        </Parameter>
        <Parameter name="VSS" unit="" default_value="VSS" show="false">
            <Description>VSS terminal net name</Description>
        </Parameter>
    </Parameters>
</Component>
