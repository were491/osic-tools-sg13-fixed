subckt schottky_nbl1(a c s)
parameters l=1e-06 w=3e-07 nx=1 ny=1 scaling=1e-06 ls=((nx*(l+2e-6))/scaling)+0.5 ws=((ny*(w+1.7e-6))/scaling)+0.5

dmain (1 c) dmain_mod  area=((nx*ny)*(l*w))/(scaling*scaling)
drev (c 1) drev_mod  area=((nx*ny)*(l*w))/(scaling*scaling)
dsub (s c) dsub_mod  area=(ls*ws)
q1 (a c s) mod1_pnp  area=((nx*ny)*(l*w))/(scaling*scaling)

rsmain (a 1) sg13g2_default_mod_r  r=(1360)/(nx*ny) tc1=2.975e-3 tc2=4.630e-6
cstray (a c) sg13g2_default_mod_c  c=(2.185e-014/25)*(nx*ny)
cin (a s) sg13g2_default_mod_c  c=(5e-016/5)*(nx)
cdsub (c 2) sg13g2_default_mod_c  c=(1.7e-014/168)*(ls*ws)
csub (2 s) sg13g2_default_mod_c  c=6e-016
rsub (2 s) sg13g2_default_mod_r  r=1e+004

ends

model mod1_pnp sp_bjt ( 
  type=-1 
  tnom=27 is=2e-18 nf=0.93304 nr=0.848 ikf=0.0128824955169313
  bf=0.287719968668579 rc=420000 rb=408 kf=6.704272e-08*schottky_nbl1_kf af=0.53
  eg=0.95
)

model dmain_mod sp_diode ( 
  tnom=27 is=3.829e-10*schottky_nbl1_is n=1.057 ik=0.07311 cj=8e-16 cjsw=0
  mj=0.569 vj=0.4 eg=0.450 xti=4.633 kf=3.16227766016838e-12*schottky_nbl1_kf
  af=1.205 tlevc=1 cta=0.001 tlev=1
)
//* + imax=10 )

model drev_mod sp_diode ( 
  tnom=27 is=2.707e-10 n=16.9 ik=1.66e-05 eg=6.5 xti=4
  kf=3.43962955648912e-09*schottky_nbl1_kf af=1.75
)

model dsub_mod sp_diode ( 
  tnom=27 is=1.141e-16 rs=19700 n=1 ik=5e-07 cj=1.5e-16 cjsw=0 mj=0.6 vj=0.5
  eg=1.17 xti=3 bv=23 tcv=-0.00079 ibv=1e-15 nbv=1 tlevc=1 cta=0.001 tlev=1
)

