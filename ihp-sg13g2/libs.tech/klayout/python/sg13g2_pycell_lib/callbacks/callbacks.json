    "moduleList": [
        "parameters.tcl",
        "util.tcl",
        "cap_cb.tcl",
        "diode_cb.tcl",
        "bondpad_cb.tcl",
        "inductor_cb.tcl",
        "isolbox_cb.tcl"
    ],
    "callbackDefinition": {
        "callbackList": [
            {
                "devices": ["cmim"],
                "callbacks": [
                    {
                        "callback": "CbCap",
                        "pcellParameters": ["C", "w", "l"]
                    }
                ]
            },
            {
                "devices": ["rfcmim"],
                "callbacks": [
                    {
                        "callback": "CbCap",
                        "pcellParameters": ["C", "w", "l"]
                    }
                ]
            },
            {
                "devices": ["SVaricap"],
                "callbacks": [
                    {
                        "callback": "CbSVaricap_wl",
                        "pcellParameters": ["w", "l"]
                    }
                ]
            },
            {
                "devices": ["dantenna"],
                "callbacks": [
                    {
                        "callback": "CbDiode",
                        "pcellParameters": ["w", "l", "a"]
                    }
                ]
            },
            {
                "devices": ["bondpad"],
                "callbacks": [
                    {
                        "callback": "CbBondpad",
                        "pcellParameters": ["topMetal", "bottomMetal"]
                    },
                    {
                        "callback": "bondpad_cb",
                        "pcellParameters": ["hwquota", "diameter", "padType", "passEncl", "FlipChip"]
                    }
                ]
            }
        ]
    }
}
